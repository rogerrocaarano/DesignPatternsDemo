@startuml

participant CreateSaleHandler
participant ApplyDiscountHandler
participant Sale
participant DiscountService
participant IDiscountStrategy
participant SaleContext

CreateSaleHandler -> ApplyDiscountHandler : HandleAsync(context)
activate ApplyDiscountHandler

ApplyDiscountHandler -> Sale : CalculateTotal()
activate Sale
Sale --> ApplyDiscountHandler : total
deactivate Sale

note over ApplyDiscountHandler
    customerForDiscount viene del contexto, 
    siendo nulo si es un cliente aún no existente.
end note

ApplyDiscountHandler -> DiscountService : GetDiscount(customerForDiscount, total)
activate DiscountService

loop por cada IDiscountStrategy registrada
    DiscountService -> IDiscountStrategy : CalculateDiscount(customer, total)
    activate IDiscountStrategy
    IDiscountStrategy --> DiscountService : discount?
    deactivate IDiscountStrategy
end

note over DiscountService
    Retorna el descuento de mayor Amount,
    o null si ninguna estrategia aplica
end note

DiscountService --> ApplyDiscountHandler : discount?
deactivate DiscountService

ApplyDiscountHandler -> SaleContext : SaleDiscount = discount

ApplyDiscountHandler -> ApplyDiscountHandler : base.HandleAsync(context)
note right : delega al siguiente handler
deactivate ApplyDiscountHandler

@enduml
