@startuml SalePipeline

class SalePipeline {
    -_firstHandler : SaleBaseHandler
    +SalePipeline(searchOrCreateCustomer: SearchOrCreateCustomerHandler, createSale: CreateSaleHandler, applyDiscount: ApplyDiscountHandler, persistSale: PersistSaleHandler)
    +HandleRequest(request: SaleRequest) : Task<SaleContext>
}

@enduml
