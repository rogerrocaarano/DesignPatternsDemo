@startuml

package Domain {
    note as nDomain
        **Capa de Dominio**
        --
        * Entidades de Negocio
        * Objetos de Valor (Value Objects)
        * Interfaces de Repositorios
    end note
}

package Business {
    note as nBusiness
        **Capa de Negocio (Aplicación)**
        --
        * Servicios de Aplicación
        * Reglas de Negocio
        * Casos de Uso
    end note
}

package DataAccess {
    note as nDataAccess
        **Capa de Acceso a Datos (Infraestructura)**
        --
        * Implementación de Repositorios
        * Contexto de Base de Datos
        * Mapeadores (Mappers)
    end note
}

package Api {
    note as nApi
        **Capa de API (Presentación)**
        --
        * Controladores / Endpoints
        * Objetos de Transferencia de Datos (DTOs)
    end note
}

' Relaciones de dependencia
DataAccess ..> Domain : Implementa
Api ..> Business : Consume
Business ..> Domain : Depende de

@enduml